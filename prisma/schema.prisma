generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                String    @id @default(cuid())
  name              String
  email             String    @unique
  password          String?
  emailVerified     DateTime?
  image             String?
  role              UserRole  @default(STUDENT)
  classId           String?

  accounts          Account[]
  sessions          Session[]

  class             Class?    @relation("ClassStudents", fields: [classId], references: [id])
  school            School?   @relation(fields: [schoolId], references: [id])
  schoolId          String?

  testsCreated      Test[]    @relation("CreatedTests")
  submissions       Submission[]
  testAssignments   TestAssignment[]
  scannedTests      ScannedTest[]

  attendanceRecords AttendanceRecord[] @relation("StudentAttendance")
  markedAttendances AttendanceRecord[] @relation("MarkedByTeacher")
  attendanceNotifications AttendanceNotification[] @relation("StudentNotifications")

  teacherSchedules  Schedule[] @relation("TeacherSchedules")
  studentEnrollments Enrollment[] @relation("StudentEnrollments")
  teacherCourseAssignments CourseAssignment[] @relation("TeacherCourseAssignments")


  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
  PARENT
}

model School {
  id        String   @id @default(cuid())
  name      String
  address   String?
  
  users     User[]
  classes   Class[]
  courses   Course[]  
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Class {
  id          String   @id @default(cuid())
  name        String
  grade       String?
  section     String?
  
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  
  students    User[]   @relation("ClassStudents")
  attendanceRecords AttendanceRecord[]
  schedules   Schedule[]  
  courseAssignments CourseAssignment[]  

  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Test {
  id          String   @id @default(cuid())
  title       String
  subject     String?
  description String?
  isPublished Boolean  @default(false)
  isActive    Boolean  @default(false)
  startDate   DateTime?
  endDate     DateTime?
  accessCode  String   @unique
  
  createdById String
  createdBy   User     @relation("CreatedTests", fields: [createdById], references: [id])
  
  questions   Question[]
  submissions Submission[]
  testAssignments TestAssignment[]
  scannedTests ScannedTest[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Question {
  id            String       @id @default(cuid())
  type          QuestionType
  content       String
  points        Int          @default(1)
  options       Json?
  correctAnswer String?
  rubric        Json?
  orderIndex    Int
  
  testId        String
  test          Test         @relation(fields: [testId], references: [id], onDelete: Cascade)
  
  answers       Answer[]
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

enum QuestionType {
  MULTIPLE_CHOICE
  SHORT_ANSWER
  ESSAY
  CODE
}

model Submission {
  id                    String           @id @default(cuid())
  status                SubmissionStatus @default(IN_PROGRESS)
  startedAt             DateTime         @default(now())
  submittedAt           DateTime?
  currentQuestionIndex  Int              @default(0)
  totalScore            Float?
  maxScore              Float?
  tabSwitchCount        Int              @default(0)
  lastActiveAt          DateTime         @default(now())
  aiGraded              Boolean          @default(false)
  
  studentId             String
  student               User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  testId                String
  test                  Test             @relation(fields: [testId], references: [id], onDelete: Cascade)
  
  answers               Answer[]
  suspiciousActivities  SuspiciousActivity[]
  
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  
  @@unique([studentId, testId])
}

enum SubmissionStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
  RELEASED
}

model Answer {
  id              String     @id @default(cuid())
  response        String
  aiScore         Float?
  aiFeedback      String?
  aiConfidence    Float?
  teacherScore    Float?
  teacherFeedback String?
  
  submissionId    String
  submission      Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  
  questionId      String
  question        Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  
  @@unique([submissionId, questionId])
}

model SuspiciousActivity {
  id           String     @id @default(cuid())
  type         String
  timestamp    DateTime
  details      Json?
  
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime   @default(now())
}

model TestAssignment {
  id         String   @id @default(cuid())
  
  testId     String
  test       Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  
  studentId  String
  student    User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  assignedBy String
  assignedAt DateTime @default(now())
  
  @@unique([testId, studentId])
}

model ScannedTest {
  id           String   @id @default(cuid())
  imageUrl     String
  answers      Json?
  aiProcessed  Boolean  @default(false)
  
  testId       String
  test         Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  
  studentId    String
  student      User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AttendanceRecord {
  id        String           @id @default(cuid())
  date      DateTime
  status    AttendanceStatus
  notes     String?
  
  studentId String
  student   User             @relation("StudentAttendance", fields: [studentId], references: [id], onDelete: Cascade)
  
  classId   String
  class     Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  
  markedById String
  markedBy   User            @relation("MarkedByTeacher", fields: [markedById], references: [id])
  
  notifications AttendanceNotification[]
  
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  
  @@unique([studentId, date])
  @@index([classId, date])
  @@index([studentId])
}

model AttendanceNotification {
  id        String           @id @default(cuid())
  type      NotificationType
  message   String
  sentAt    DateTime         @default(now())
  
  studentId String
  student   User             @relation("StudentNotifications", fields: [studentId], references: [id], onDelete: Cascade)
  
  recordId  String
  record    AttendanceRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  
  @@index([studentId])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum NotificationType {
  SMS
  EMAIL
  PUSH
}

model Course {
  id          String   @id @default(cuid())
  code        String   @unique // e.g., "MATH101"
  name        String   // e.g., "Introduction to Calculus"
  description String?
  credits     Int      @default(3)
  grade       String?  // e.g., "9", "10", "11", "12"
  
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  
  schedules   Schedule[]
  enrollments Enrollment[]
  assignments CourseAssignment[]  

  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Schedule {
  id          String   @id @default(cuid())
  
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  teacherId   String
  teacher     User     @relation("TeacherSchedules", fields: [teacherId], references: [id], onDelete: Cascade)
  
  classId     String?
  class       Class?   @relation(fields: [classId], references: [id], onDelete: SetNull)
  
  dayOfWeek   Int      // 0 = Monday, 1 = Tuesday, ..., 6 = Sunday
  startTime   String   // e.g., "09:00"
  endTime     String   // e.g., "10:00"
  room        String?  // e.g., "Room 101"
  
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([courseId, dayOfWeek, startTime])
}

model Enrollment {
  id          String   @id @default(cuid())
  
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  studentId   String
  student     User     @relation("StudentEnrollments", fields: [studentId], references: [id], onDelete: Cascade)
  
  enrolledAt  DateTime @default(now())
  status      EnrollmentStatus @default(ACTIVE)
  
  grade       Float?   // Final grade
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([courseId, studentId])
}
model CourseAssignment {
  id            String   @id @default(cuid())
  
  courseId      String
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  teacherId     String
  teacher       User     @relation("TeacherCourseAssignments", fields: [teacherId], references: [id], onDelete: Cascade)
  
  classId       String?
  class         Class?   @relation(fields: [classId], references: [id], onDelete: SetNull)
  
  weeklyHours   Int      @default(4)  // How many hours per week
  
  preferences   Json?    // Preferred days/times
  
  isScheduled   Boolean  @default(false)  // Has AI generated schedule?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([courseId, teacherId, classId])
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
  WITHDRAWN
}