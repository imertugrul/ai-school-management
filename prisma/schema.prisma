generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                String    @id @default(cuid())
  name              String
  email             String    @unique
  password          String?
  emailVerified     DateTime?
  image             String?
  role              UserRole  @default(STUDENT)
  subject           String?
  classId           String?

  accounts          Account[]
  sessions          Session[]
  studentGrades    Grade[]  @relation("StudentGrades")

  class             Class?    @relation("ClassStudents", fields: [classId], references: [id])
  school            School?   @relation(fields: [schoolId], references: [id])
  schoolId          String?

  testsCreated      Test[]    @relation("CreatedTests")
  submissions       Submission[]
  testAssignments   TestAssignment[]
  scannedTests      ScannedTest[]

  attendanceRecords AttendanceRecord[] @relation("StudentAttendance")
  markedAttendances AttendanceRecord[] @relation("MarkedByTeacher")
  attendanceNotifications AttendanceNotification[] @relation("StudentNotifications")

  teacherSchedules  Schedule[] @relation("TeacherSchedules")
  studentEnrollments Enrollment[] @relation("StudentEnrollments")
  teacherCourseAssignments CourseAssignment[] @relation("TeacherCourseAssignments")

  department            String?

  // 2FA fields
  twoFactorEnabled      Boolean  @default(false)
  twoFactorSecret       String?
  twoFactorVerified     Boolean  @default(false)

  authoredAnnouncements Announcement[] @relation("AuthorAnnouncements")
  organizedEvents       Event[]        @relation("EventOrganizer")
  eventRSVPs            EventRSVP[]    @relation("UserEventRSVP")
  lessonPlans           LessonPlan[]   @relation("TeacherLessonPlans")
  teachingNotes         TeachingNote[] @relation("TeacherNotes")
  notesAboutMe          TeachingNote[] @relation("StudentNotes")
  parentLinks           ParentStudent[] @relation("ParentLinks")
  childLinks            ParentStudent[] @relation("ChildLinks")
  guardians             Guardian[]      @relation("StudentGuardians")
  teacherBulletins      PerformanceBulletin[] @relation("TeacherBulletins")
  studentBulletins      PerformanceBulletin[] @relation("StudentBulletins")
  guardianProfile       Guardian[]      @relation("GuardianUser")
  libraryQuestions      LibraryQuestion[] @relation("TeacherLibrary")
  socialPosts           SocialPost[]   @relation("AuthorPosts")
  mediaLibrary          MediaLibraryItem[] @relation("MediaLibrary")

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
  PARENT
  SOCIAL_MEDIA_MANAGER
}

model School {
  id        String   @id @default(cuid())
  name      String

  // Schedule Settings
  schoolStartTime    String?  @default("08:00")  // School starts
  schoolEndTime      String?  @default("16:00")  // School ends
  lessonDuration     Int?     @default(45)       // Minutes per lesson
  breakDuration      Int?     @default(10)       // Minutes between lessons
  lunchBreakStart    String?  @default("12:00")
  lunchBreakEnd      String?  @default("13:00")

  // AI Credits
  aiCreditsUsed      Int      @default(0)
  aiCreditsLimit     Int      @default(500)
  aiCreditsResetAt   DateTime?

  users     User[]
  classes   Class[]
  courses   Course[]
  announcements Announcement[]
  events        Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Class {
  id          String   @id @default(cuid())
  name        String
  grade       String?
  section     String?

  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  students    User[]   @relation("ClassStudents")
  attendanceRecords AttendanceRecord[]
  schedules   Schedule[]
  courseAssignments CourseAssignment[]
  announcements    Announcement[]
  eventTargets     Event[]
  bulletins         PerformanceBulletin[]
  lessonPlanClasses LessonPlan[]
  teachingNoteClasses TeachingNote[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Test {
  id          String   @id @default(cuid())
  title       String
  subject     String?
  description String?
  isPublished Boolean  @default(false)
  isActive    Boolean  @default(false)
  startDate   DateTime?
  endDate     DateTime?
  accessCode  String   @unique
  
  createdById String
  createdBy   User     @relation("CreatedTests", fields: [createdById], references: [id])
  
  questions      Question[]
  contentBlocks  ContentBlock[]
  submissions    Submission[]
  testAssignments TestAssignment[]
  scannedTests   ScannedTest[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Question {
  id            String       @id @default(cuid())
  type          QuestionType
  content       String       @db.Text
  points        Int          @default(1)
  options       Json?
  correctAnswer String?      @db.Text
  rubric        Json?
  config        Json?
  tags          String[]     @default([])
  orderIndex    Int

  testId        String
  test          Test         @relation(fields: [testId], references: [id], onDelete: Cascade)

  answers       Answer[]

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

enum QuestionType {
  // Legacy
  MULTIPLE_CHOICE
  SHORT_ANSWER
  ESSAY
  CODE
  // New
  MCQ_MULTIPLE
  TRUE_FALSE
  FILL_TEXT
  FILL_DROPDOWN
  MATCH
  SORT
  CLASSIFY
  TABLE
  DRAWING
  LABEL_DRAG
  LABEL_FILL
  HOTSPOT
  GEOGEBRA
  DESMOS
  AUDIO_RESPONSE
  GROUP
}

enum ContentBlockType {
  TEXT
  ACCORDION
  IMAGE
  PDF
  VIDEO
  AUDIO
  SIMULATION
  DOCUMENT
  PPT
  EMBED
}

model ContentBlock {
  id         String           @id @default(cuid())
  testId     String
  test       Test             @relation(fields: [testId], references: [id], onDelete: Cascade)
  type       ContentBlockType
  content    Json
  orderIndex Int
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}

model LibraryQuestion {
  id            String       @id @default(cuid())
  teacherId     String
  teacher       User         @relation("TeacherLibrary", fields: [teacherId], references: [id], onDelete: Cascade)
  type          QuestionType
  content       String       @db.Text
  points        Int          @default(1)
  options       Json?
  correctAnswer String?      @db.Text
  rubric        Json?
  config        Json?
  tags          String[]     @default([])
  subject       String?
  timesUsed     Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Submission {
  id                    String           @id @default(cuid())
  status                SubmissionStatus @default(IN_PROGRESS)
  startedAt             DateTime         @default(now())
  submittedAt           DateTime?
  currentQuestionIndex  Int              @default(0)
  totalScore            Float?
  maxScore              Float?
  tabSwitchCount        Int              @default(0)
  lastActiveAt          DateTime         @default(now())
  aiGraded              Boolean          @default(false)
  
  studentId             String
  student               User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  testId                String
  test                  Test             @relation(fields: [testId], references: [id], onDelete: Cascade)
  
  answers               Answer[]
  suspiciousActivities  SuspiciousActivity[]
  
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  
  @@unique([studentId, testId])
}

enum SubmissionStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
  RELEASED
}

model Answer {
  id              String     @id @default(cuid())
  response        String
  aiScore         Float?
  aiFeedback      String?
  aiConfidence    Float?
  teacherScore    Float?
  teacherFeedback String?
  
  submissionId    String
  submission      Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  
  questionId      String
  question        Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  
  @@unique([submissionId, questionId])
}

model SuspiciousActivity {
  id           String     @id @default(cuid())
  type         String
  timestamp    DateTime
  details      Json?
  
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime   @default(now())
}

model TestAssignment {
  id         String   @id @default(cuid())
  
  testId     String
  test       Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  
  studentId  String
  student    User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  assignedBy String
  assignedAt DateTime @default(now())
  
  @@unique([testId, studentId])
}

model ScannedTest {
  id           String   @id @default(cuid())
  imageUrl     String
  answers      Json?
  aiProcessed  Boolean  @default(false)
  
  testId       String
  test         Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  
  studentId    String
  student      User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AttendanceRecord {
  id        String           @id @default(cuid())
  date      DateTime
  status    AttendanceStatus
  notes     String?
  
  studentId String
  student   User             @relation("StudentAttendance", fields: [studentId], references: [id], onDelete: Cascade)
  
  classId   String
  class     Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  
  markedById String
  markedBy   User            @relation("MarkedByTeacher", fields: [markedById], references: [id])
  
  notifications AttendanceNotification[]
  
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  
  @@unique([studentId, date])
  @@index([classId, date])
  @@index([studentId])
}

model AttendanceNotification {
  id        String           @id @default(cuid())
  type      NotificationType
  message   String
  sentAt    DateTime         @default(now())
  
  studentId String
  student   User             @relation("StudentNotifications", fields: [studentId], references: [id], onDelete: Cascade)
  
  recordId  String
  record    AttendanceRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  
  @@index([studentId])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum NotificationType {
  SMS
  EMAIL
  PUSH
}

model Course {
  id          String   @id @default(cuid())
  code        String   @unique // e.g., "MATH101"
  name        String   // e.g., "Introduction to Calculus"
  description String?
  credits     Int      @default(3)
  grade       String?  // e.g., "9", "10", "11", "12"
  weeklyHours Int      @default(4)  // BU SATIRI EKLE

  gradeComponents  GradeComponent[]
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  
  schedules   Schedule[]
  enrollments Enrollment[]
  assignments CourseAssignment[]
  lessonPlans LessonPlan[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Schedule {
  id          String   @id @default(cuid())
  
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  teacherId   String
  teacher     User     @relation("TeacherSchedules", fields: [teacherId], references: [id], onDelete: Cascade)
  
  classId     String?
  class       Class?   @relation(fields: [classId], references: [id], onDelete: SetNull)
  
  dayOfWeek   Int      // 0=Monday, 6=Sunday
  startTime   String   // HH:MM format
  endTime     String   // HH:MM format
  room        String?
  
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([teacherId, dayOfWeek, startTime])
}

model Enrollment {
  id          String   @id @default(cuid())
  
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  studentId   String
  student     User     @relation("StudentEnrollments", fields: [studentId], references: [id], onDelete: Cascade)
  
  enrolledAt  DateTime @default(now())
  status      EnrollmentStatus @default(ACTIVE)
  
  grade       Float?   // Final grade
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([courseId, studentId])
}
model CourseAssignment {
  id            String   @id @default(cuid())
  
  courseId      String
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  teacherId     String
  teacher       User     @relation("TeacherCourseAssignments", fields: [teacherId], references: [id], onDelete: Cascade)
  
  classId       String?
  class         Class?   @relation(fields: [classId], references: [id], onDelete: SetNull)
  
  weeklyHours   Int      @default(4)  // How many hours per week
  
  preferences   Json?    // Preferred days/times
  
  isScheduled   Boolean  @default(false)  // Has AI generated schedule?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([courseId, teacherId, classId])
}

model GradeComponent {
  id          String   @id @default(cuid())
  
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  name        String   // "Midterm Exam", "Final Exam", "Homework 1"
  type        GradeType // EXAM, QUIZ, HOMEWORK, PROJECT, PARTICIPATION
  weight      Float    // 0.3 = 30%
  maxScore    Float    // 100
  date        DateTime?
  
  grades      Grade[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Grade {
  id              String   @id @default(cuid())
  
  componentId     String
  component       GradeComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)
  
  studentId       String
  student         User     @relation("StudentGrades", fields: [studentId], references: [id], onDelete: Cascade)
  
  score           Float    // Actual score (e.g., 85)
  feedback        String?  // Teacher comments
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([componentId, studentId])
}

enum GradeType {
  EXAM
  QUIZ
  HOMEWORK
  PROJECT
  PARTICIPATION
  ATTENDANCE
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
  WITHDRAWN
}

// ─── Priority Enum ───
enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── NoteType Enum ───
enum NoteType {
  GENERAL
  STUDENT_BEHAVIOR
  STUDENT_PROGRESS
  CLASS_OBSERVATION
  MEETING
}

// ─── Announcements ───
model Announcement {
  id          String    @id @default(cuid())
  title       String
  content     String    @db.Text
  authorId    String
  author      User      @relation("AuthorAnnouncements", fields: [authorId], references: [id], onDelete: Cascade)
  priority    Priority  @default(MEDIUM)
  category    String    @default("General")
  targetRoles String[]  @default([])
  targetClassId String?
  targetClass   Class?  @relation(fields: [targetClassId], references: [id], onDelete: SetNull)
  isPinned    Boolean   @default(false)
  publishedAt DateTime  @default(now())
  expiresAt   DateTime?
  schoolId    String
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── Events ───
model Event {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  location    String?
  startDate   DateTime
  endDate     DateTime
  isAllDay    Boolean   @default(false)
  category    String    @default("General")
  color       String?
  targetRoles String[]  @default([])
  targetClassId String?
  targetClass   Class?  @relation(fields: [targetClassId], references: [id], onDelete: SetNull)
  organizerId String
  organizer   User      @relation("EventOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  rsvps       EventRSVP[]
  schoolId    String
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model EventRSVP {
  id        String     @id @default(cuid())
  eventId   String
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation("UserEventRSVP", fields: [userId], references: [id], onDelete: Cascade)
  status    String
  createdAt DateTime   @default(now())
  @@unique([eventId, userId])
}

// ─── Lesson Plans ───
enum CurriculumType {
  IB
  AP
  NATIONAL
  IGCSE
  COMMON_CORE
}

model LessonPlan {
  id          String    @id @default(cuid())
  teacherId   String
  teacher     User      @relation("TeacherLessonPlans", fields: [teacherId], references: [id], onDelete: Cascade)
  courseId    String
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  classId     String?
  class       Class?    @relation(fields: [classId], references: [id], onDelete: SetNull)

  // Manual plan fields (existing)
  title       String    @default("")
  date        DateTime  @default(now())
  objectives  String    @db.Text @default("")
  materials   String?   @db.Text
  activities  String    @db.Text @default("")
  assessment  String?   @db.Text
  homework    String?   @db.Text
  notes       String?   @db.Text

  // AI-powered fields
  curriculumType     CurriculumType?
  unitName           String?
  learningObjectives String?  @db.Text  // JSON array
  materialsNeeded    String?  @db.Text  // JSON array
  slideOutline       String?  @db.Text  // JSON array
  aiActivities       String?  @db.Text  // JSON array
  aiAssessment       String?  @db.Text  // JSON object
  teacherNotes       String?  @db.Text
  isAIGenerated      Boolean  @default(false)
  wasEdited          Boolean  @default(false)
  schoolId           String?

  duration    Int       @default(45)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── Teaching Notes ───
model TeachingNote {
  id          String    @id @default(cuid())
  teacherId   String
  teacher     User      @relation("TeacherNotes", fields: [teacherId], references: [id], onDelete: Cascade)
  studentId   String?
  student     User?     @relation("StudentNotes", fields: [studentId], references: [id], onDelete: Cascade)
  classId     String?
  class       Class?    @relation(fields: [classId], references: [id], onDelete: SetNull)
  title       String
  content     String    @db.Text
  type        NoteType  @default(GENERAL)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── Parent–Student Link ───
model ParentStudent {
  id           String  @id @default(cuid())
  parentId     String
  parent       User    @relation("ParentLinks", fields: [parentId], references: [id], onDelete: Cascade)
  studentId    String
  student      User    @relation("ChildLinks", fields: [studentId], references: [id], onDelete: Cascade)
  relationship String  @default("Guardian")
  @@unique([parentId, studentId])
}

// ─── Social Media Hub ───

enum SocialPlatform {
  INSTAGRAM
  TWITTER
  FACEBOOK
  LINKEDIN
  YOUTUBE
  TIKTOK
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum VoiceTone {
  PROFESSIONAL
  CASUAL
  EDUCATIONAL
  INSPIRATIONAL
}

model SocialPost {
  id           String          @id @default(cuid())
  title        String?
  content      String          @db.Text
  platforms    SocialPlatform[]
  mediaUrls    Json?           // array of { url, type, name }
  status       PostStatus      @default(DRAFT)
  scheduledFor DateTime?
  publishedAt  DateTime?
  tags         String[]        @default([])
  analytics    Json?           // { platform: { views, likes, shares, comments } }
  notes        String?         @db.Text

  authorId     String
  author       User            @relation("AuthorPosts", fields: [authorId], references: [id], onDelete: Cascade)

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([authorId])
  @@index([status])
  @@index([scheduledFor])
}

// ─── KVKK / GDPR Deletion Log ───
model GdprLog {
  id            String   @id @default(cuid())
  studentName   String
  studentEmail  String
  deletedBy     String   // admin email
  parentEmailed Boolean  @default(false)
  parentEmail   String?
  deletedAt     DateTime @default(now())

  @@index([deletedAt])
}

// ─── AI Audit Log (KVKK/GDPR) ───
model AiLog {
  id              String   @id @default(cuid())
  endpoint        String
  tokensUsed      Int      @default(0)
  hasPersonalData Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([createdAt])
  @@index([endpoint])
}

model MediaLibraryItem {
  id        String   @id @default(cuid())
  authorId  String
  author    User     @relation("MediaLibrary", fields: [authorId], references: [id], onDelete: Cascade)
  name      String
  url       String
  type      String   // image, video, audio, document
  size      Int
  tags      String[] @default([])
  createdAt DateTime @default(now())

  @@index([authorId])
}

model BrandSettings {
  id              String     @id @default(cuid())
  schoolId        String     @unique
  primaryColor    String     @default("#3B82F6")
  secondaryColor  String     @default("#8B5CF6")
  accentColor     String     @default("#10B981")
  logoUrl         String?
  coverUrl        String?
  organizationName String    @default("")
  tagline         String?
  voiceTone       VoiceTone  @default(PROFESSIONAL)
  hashtags        String[]   @default([])
  forbiddenWords  String[]   @default([])
  instagramHandle String?
  twitterHandle   String?
  facebookPage    String?
  linkedinPage    String?
  youtubeChannel  String?
  tiktokHandle    String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}
// ─── Guardian (Veli Bilgileri) ─────────────────────────────────────────────
model Guardian {
  id            String   @id @default(cuid())
  studentId     String
  student       User     @relation("StudentGuardians", fields: [studentId], references: [id], onDelete: Cascade)

  name          String
  relationship  String   // "Anne", "Baba", "Vasi", "Diğer"
  email         String?
  phone         String?

  isPrimary     Boolean  @default(false)
  receivesEmail Boolean  @default(true)
  receivesSMS   Boolean  @default(false)

  note          String?  @db.Text   // Sadece admin görebilir

  // Eğer bu velinin sistem hesabı varsa bağla (opsiyonel)
  userId        String?
  user          User?    @relation("GuardianUser", fields: [userId], references: [id], onDelete: SetNull)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([studentId])
  @@index([userId])
}

// ─── Performance Bulletin ─────────────────────────────────────────────────────
enum BulletinStatus {
  DRAFT
  READY
  SENT
}

model PerformanceBulletin {
  id          String  @id @default(cuid())
  teacherId   String
  teacher     User    @relation("TeacherBulletins", fields: [teacherId], references: [id], onDelete: Cascade)
  studentId   String
  student     User    @relation("StudentBulletins", fields: [studentId], references: [id], onDelete: Cascade)
  classId     String
  class       Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  month       String  // "2026-03"

  attendancePresent Int    @default(0)
  attendanceAbsent  Int    @default(0)
  attendanceLate    Int    @default(0)
  gradeAverage      Float?
  gradeDetails      Json?  // [{ courseId, courseName, average }]

  participationRating Int?
  behaviorRating      Int?
  homeworkRating      Int?
  strengthAreas       String?
  improvementAreas    String?
  teacherComment      String? @db.Text

  status      BulletinStatus @default(DRAFT)
  sentAt      DateTime?
  sentToCount Int            @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([teacherId, studentId, month])
  @@index([classId, month])
}
