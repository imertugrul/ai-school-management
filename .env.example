# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ai_grading?schema=public"

# Authentication
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# AI Providers (choose one or use both)
OPENAI_API_KEY="your-openai-api-key-here"
