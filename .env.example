# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ai_grading?schema=public"

# Authentication
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# AI Providers (choose one or use both)
OPENAI_API_KEY="your-openai-api-key-here"
ANTHROPIC_API_KEY="your-anthropic-api-key-here"

# File Storage (for scanned tests - Phase 2)
# AWS_ACCESS_KEY_ID="your-aws-key"
# AWS_SECRET_ACCESS_KEY="your-aws-secret"
# AWS_REGION="us-east-1"
# AWS_S3_BUCKET="your-bucket-name"

# OCR Service (for scanned tests - Phase 2)
# GOOGLE_CLOUD_VISION_API_KEY="your-google-api-key"

# Email (Resend) — required for KVKK deletion notifications
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="noreply@schoolpro.ai"

# Admin panel path — change to hide the panel URL (default: manage-panel)
ADMIN_PATH=manage-panel
NEXT_PUBLIC_ADMIN_PATH=manage-panel

# Rate limiting (Upstash Redis) — optional; falls back to in-memory if not set
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 2FA app name shown in authenticator apps
APP_NAME=SchoolPro

# Twilio WhatsApp — required for WhatsApp absence notifications
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
